# =============================================
# IL JOLLY LEGALE - Variabili d'Ambiente
# =============================================
# ISTRUZIONI:
# 1. Copia questo file: cp .env.example .env
# 2. Sostituisci i valori segnaposto con le tue chiavi reali
# 3. NON committare mai il file .env su Git!

# --- Groq (gratuito su console.groq.com) ---
GROQ_API_KEY="gsk_..."

# --- Modello LLM ---
LLM_MODEL="llama-3.3-70b-versatile"

# --- Chunking ottimizzato per testi legali ---
CHUNK_SIZE=1500
CHUNK_OVERLAP=400

# Limite pagine per la demo gratuita
PAGE_LIMIT=30
